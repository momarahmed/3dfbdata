# CrowdSim 3D — root .env (used by docker-compose)
# Copy to `.env` and tweak as needed.

# ---- Host ports (change if occupied) ---------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- Chrome DevTools (optional; use when frontend runs in Docker) -----------
# Fixes "Unable to add filesystem: <illegal path>" in DevTools — set to the host path of ./frontend
# (forward slashes are fine on Windows), e.g. C:/Users/you/Downloads/3dfbdata/frontend
# NEXT_DEVTOOLS_WORKSPACE_ROOT=
# NEXT_DEVTOOLS_WORKSPACE_UUID=

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=crowdsim
POSTGRES_USER=crowdsim
POSTGRES_PASSWORD=crowdsim_secret
